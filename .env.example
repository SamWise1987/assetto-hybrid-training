# Admin emails (comma-separated) — promoted to admin on first login via /api/me
ASSETTO_ADMIN_EMAILS=your@email.com
NEXT_PUBLIC_ADMIN_EMAILS=your@email.com

# Supabase — account, dati condivisi, realtime e sync (progetto hybrid-training, eu-west-3)
# Dashboard: Settings → API Keys → tab "Publishable and secret API keys"
NEXT_PUBLIC_SUPABASE_URL=https://navyoqbpldsptejnnopk.supabase.co
# Publishable key (client/browser) — sostituisce la vecchia anon key
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
# Secret key (solo server/API routes) — sostituisce la vecchia service_role key
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# OpenAI — coach AI per progressi allenamento (opzionale, solo server)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini

# Strava — import corse (OAuth, server-side)
# Crea app su https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Locale: http://localhost:3000 — produzione: https://assetto-hybrid-training.vercel.app
NEXT_PUBLIC_APP_URL=https://assetto-hybrid-training.vercel.app

# Capacitor — URL caricato nel WebView nativo (stesso dominio di produzione)
CAPACITOR_SERVER_URL=https://assetto-hybrid-training.vercel.app

# Web Push (genera una coppia VAPID, ad esempio con `npx web-push generate-vapid-keys`)
NEXT_PUBLIC_WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:privacy@robertafunctional.app

# Android Push — Firebase Cloud Messaging HTTP v1 (solo server)
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# iOS Push — APNs token authentication (solo server)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
APNS_BUNDLE_ID=com.robertafunctional.app
APNS_ENVIRONMENT=development
